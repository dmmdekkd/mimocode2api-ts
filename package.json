{
  "name": "mimocode2api-ts",
  "version": "0.1.1",
  "description": "OpenAI-compatible reverse proxy for Xiaomi Mimo AI (TypeScript port).",
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "mimocode2api": "bin.ts"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun run build:bun && bun run build:node && bun run build:bin",
    "build:bun": "bun build src/main.ts --outdir dist/bun --target bun",
    "build:node": "bun build src/main.ts --target node --outfile dist/node/mimocode2api.cjs",
    "build:bin": "bun run build:bin:win-x64 && bun run build:bin:mac-x64 && bun run build:bin:mac-arm64 && bun run build:bin:linux-x64 && bun run build:bin:linux-arm64",
    "build:bin:win-x64": "bun build src/main.ts --compile --target=bun-windows-x64 --outfile dist/bin-win-x64/mimocode2api.exe",
    "build:bin:mac-x64": "bun build src/main.ts --compile --target=bun-darwin-x64 --outfile dist/bin-mac-x64/mimocode2api",
    "build:bin:mac-arm64": "bun build src/main.ts --compile --target=bun-darwin-arm64 --outfile dist/bin-mac-arm64/mimocode2api",
    "build:bin:linux-x64": "bun build src/main.ts --compile --target=bun-linux-x64 --outfile dist/bin-linux-x64/mimocode2api",
    "build:bin:linux-arm64": "bun build src/main.ts --compile --target=bun-linux-arm64 --outfile dist/bin-linux-arm64/mimocode2api",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "bun-types": "^1.1.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0"
  }
}
